    Component {
      Type          CScript
      Name          "Planta"
      Show          on
      Position      [2840, 765]
      Direction     up
      Flipped       off
      LabelPosition south
      Parameter {
        Variable      "DialogGeometry"
        Value         "[222 270 820 1004]"
        Show          off
      }
      Parameter {
        Variable      "NumInputs"
        Value         "5"
        Show          off
      }
      Parameter {
        Variable      "NumOutputs"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "NumContStates"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "NumDiscStates"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "NumZCSignals"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "DirectFeedthrough"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "Ts"
        Value         "1/(fclk)"
        Show          off
      }
      Parameter {
        Variable      "TerminalBasedSampleTimes"
        Value         "1"
        Show          off
      }
      Parameter {
        Variable      "Parameters"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "LangStandard"
        Value         "2"
        Show          off
      }
      Parameter {
        Variable      "GnuExtensions"
        Value         "2"
        Show          off
      }
      Parameter {
        Variable      "RuntimeCheck"
        Value         "2"
        Show          off
      }
      Parameter {
        Variable      "HighlightLevel"
        Value         "0"
        Show          off
      }
      Parameter {
        Variable      "Declarations"
        Value         "#include <math.h>\n"
"\n"
"//#define DT  (1.0/15000000)\n"
"//#define Vdc 400.0\n"
"//#define Lf  0.003 //0.003\n"
"//#define Rf  0.0377 //0.0377\n"
"\n"
"#define S1 Input(0)\n"
"#define S2 Input(1)\n"
"#define S3 Input(2)\n"
"#define S4 Input(3)\n"
"#define VG Input(4)\n"
"\n"
"\n"
"\n"
"// estados\n"
"static double iL;\n"
"static double i_old;\n"
"\n"
"static double u;\n"
"static double u_old;\n"
"\n"
"static double vconv;\n"
"\n"
"// variavel de estado do full bridge\n"
"\n"
"static double S;\n"
"static double S_old;\n"
"\n"
"//====================================================\n"
"// memoria da rede\n"
"//====================================================\n"
"\n"
"static double VG_old;\n"
"\n"
"// coeficientes Tustin\n"
"static double A;\n"
"static double B;\n"
"static double K;\n"
"\n"
"static double DT = 6.666667e-8;\n"
"static double Vdc = 400;\n"
"static double Lf = 0.003;\n"
"static double Rf = 0.0377;"
        Show          off
      }
      Parameter {
        Variable      "StartFcn"
        Value         "//_____________________________________________________"
"_____________\n"
"\n"
"\n"
"// inicializacao estados\n"
"iL    = 0.0;\n"
"i_old = 0.0;\n"
"\n"
"u     = 0.0;\n"
"u_old = 0.0;\n"
"\n"
"//----------------------------------------------------\n"
"// coeficientes metodo trapezoidal / Tustin\n"
"//\n"
"// i[k] = A*i[k-1] + B*(u[k] + u[k-1])\n"
"//\n"
"// A = (1 - R*DT/(2L)) / (1 + R*DT/(2L))\n"
"// B = (Ts/(2L))       / (1 + R*DT/(2L))\n"
"//----------------------------------------------------\n"
"\n"
"A = (1.0 - (Rf*DT)/(2.0*Lf)) / (1.0 + (Rf*DT)/(2.0*Lf));\n"
"\n"
"//B = (DT/(4.0*Lf)) / (1.0 + (2*Rf*DT)/(4.0*Lf));\n"
"\n"
"B = 1*((DT/(4.0*Lf)) / (1.0 + (2*Rf*DT)/(4.0*Lf)));\n"
"\n"
"K = (B*Vdc)/2.0;"
        Show          off
      }
      Parameter {
        Variable      "OutputFcn"
        Value         "// Full bridge unipolar\n"
"\n"
"//if(S1==1 && S4==1)\n"
"//    vconv = Vdc;\n"
"//else if(S2==1 && S3==1)\n"
"//    vconv = -Vdc;\n"
"//else\n"
"//    vconv = 0.0;\n"
"\n"
"\n"
"// modelo discreto exato\n"
"//iL = a*iL + b*(vconv - VG);\n"
"\n"
"//Output(0)=iL;\n"
"\n"
"\n"
"//=============================\n"
"\n"
"//----------------------------------------------------\n"
"// tensao de saida full bridge\n"
"//----------------------------------------------------\n"
"\n"
"//if(S1==1 && S4==1)\n"
"//    vconv =  Vdc;\n"
"\n"
"//else if(S2==1 && S3==1)\n"
"//    vconv = -Vdc;\n"
"\n"
"//else\n"
"//    vconv = 0.0;\n"
"\n"
"S = (S1-S2-S3+S4);\n"
"//vconv = (Vdc/2)*S;\n"
"\n"
"//----------------------------------------------------\n"
"// entrada da planta\n"
"//----------------------------------------------------\n"
"i_old = iL;\n"
"//u_old = u;\n"
"S_old = S;\n"
"VG_old = VG;\n"
"\n"
"u = vconv - VG;\n"
"\n"
"\n"
"//----------------------------------------------------\n"
"// planta discreta - metodo trapezoidal / Tustin\n"
"//----------------------------------------------------\n"
"\n"
"//iL = A*i_old + B*(u + u_old);\n"
"iL = A*i_old + K*(S + S_old) - B*(VG + VG_old);\n"
"\n"
"//----------------------------------------------------\n"
"// atualiza memorias\n"
"//----------------------------------------------------\n"
"\n"
"\n"
"\n"
"\n"
"//----------------------------------------------------\n"
"// saida\n"
"//----------------------------------------------------\n"
"\n"
"Output(0) = iL;"
        Show          off
      }
      Parameter {
        Variable      "UpdateFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "DerivativeFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "TerminateFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "StoreCustomStateFcn"
        Value         ""
        Show          off
      }
      Parameter {
        Variable      "RestoreCustomStateFcn"
        Value         ""
        Show          off
      }
    }
